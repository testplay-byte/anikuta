<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required to install downloaded extension APKs on Android 8+ (API 26+).
         Without this, ACTION_VIEW on a content:// URI to an .apk silently
         fails. aniyomi declares the same permission. Safe for sideloaded apps;
         Google Play restricts it but we don't distribute via Play. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Required to discover installed anime extensions on Android 11+ (API 30+).
         Without this, PackageManager.getInstalledPackages() only returns packages
         with a matching <queries> declaration, so installed extensions are invisible
         and the source chain shows "zero sources available". aniyomi uses the same
         permission. Safe for sideloaded apps; Google Play restricts it but we don't
         distribute via Play. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Allow intent-based extension discovery on Android 11+ (package
         visibility). The intent-based fallback in AnimeExtensionLoader uses
         queryIntentActivities(Intent("tachiyomi.animeextension")). Without
         this <queries> declaration, that query returns nothing on API 30+. -->
    <queries>
        <intent>
            <action android:name="tachiyomi.animeextension" />
        </intent>
    </queries>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ANI-KUTA"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Anikuta">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Anikuta">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- AniList OAuth callback (Phase 6 task 6.7). Uses aniyomi's
                 redirect URI because we use their client ID (5338). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="aniyomi" android:host="anilist-auth" />
            </intent-filter>
        </activity>

        <!-- MPV video player. Landscape + fullscreen at runtime; theme from manifest. -->
        <activity
            android:name=".player.PlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden|navigation|uiMode|fontScale"
            android:screenOrientation="sensorLandscape"
            android:theme="@style/Theme.Anikuta" />

        <!-- Global crash screen. Shown by AnikutaCrashHandler when the app crashes. -->
        <activity
            android:name=".error.ErrorActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Anikuta" />

        <!-- FileProvider for sharing downloaded extension APKs with the system
             package installer (ExtensionsViewModel.installExtension). The
             authority is "${applicationId}.fileprovider" — matches the runtime
             lookup `Context.packageName + ".fileprovider"`. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
