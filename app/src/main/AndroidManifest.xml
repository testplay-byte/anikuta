<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ANI-KUTA"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Anikuta">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Anikuta">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MPV video player. Landscape + fullscreen at runtime; theme from manifest. -->
        <activity
            android:name=".player.PlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden|navigation|uiMode|fontScale"
            android:screenOrientation="sensorLandscape"
            android:theme="@style/Theme.Anikuta" />

        <!-- Global crash screen. Shown by AnikutaCrashHandler when the app crashes. -->
        <activity
            android:name=".error.ErrorActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Anikuta" />
    </application>

</manifest>
