<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) traffic to localhost and 127.0.0.1.
         This is required for the extension HTTP proxy (localhost:PORT) which
         serves m3u8 playlists and video segments. The proxy is local — traffic
         never leaves the device — so cleartext is safe here.
         
         All other traffic must use HTTPS (enforced by default). -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
